<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>LingoAce – <%= title %></title>
  <link rel="stylesheet" href="/css/base.css"/>
  <link rel="stylesheet" href="/css/layout.css"/>
  <link rel="stylesheet" href="/css/payment.css"/>
</head>
<body>
  <%- include('partials/topbar') %>
  <%- include('partials/navbar') %>

  <div class="checkout-shell">
    <div class="checkout-back">
      <a href="/book-class" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Back to Book Class
      </a>
    </div>

    <div class="payment-page-layout">
      <!-- Package summary -->
      <div class="payment-pkg-summary">
        <div class="payment-pkg-logo">
          <svg width="28" height="28" viewBox="0 0 40 40">
            <circle cx="20" cy="20" r="20" fill="#6B5ECD"/>
            <ellipse cx="20" cy="22" rx="10" ry="8" fill="#F5A623"/>
            <circle cx="16" cy="18" r="3" fill="#fff"/>
            <circle cx="24" cy="18" r="3" fill="#fff"/>
            <circle cx="16" cy="18" r="1.5" fill="#333"/>
            <circle cx="24" cy="18" r="1.5" fill="#333"/>
          </svg>
          <span class="payment-pkg-brand">LingoAce</span>
        </div>
        <div class="payment-pkg-detail">
          <p class="payment-pkg-name"><%= pkg.name %></p>
          <p class="payment-pkg-price"><%= pkg.displayPrice %></p>
        </div>
      </div>

      <!-- Payment method card -->
      <div class="payment-card">
        <h2 class="payment-card-title">Select payment method</h2>

        <form action="/checkout" method="GET" id="payment-form">
          <input type="hidden" name="package" value="<%= packageKey %>"/>

          <div class="pm-list">

            <!-- Alipay -->
            <label class="pm-option">
              <input type="radio" name="method" value="alipay" required/>
              <span class="pm-radio"></span>
              <span class="pm-icon">
                <svg width="28" height="28" viewBox="0 0 40 40"><rect width="40" height="40" rx="8" fill="#1677FF"/><text x="50%" y="57%" dominant-baseline="middle" text-anchor="middle" font-size="9" font-weight="800" fill="#fff">支付宝</text></svg>
              </span>
              <span class="pm-label">支付宝</span>
            </label>

            <!-- WeChat Pay -->
            <label class="pm-option">
              <input type="radio" name="method" value="wechat" required/>
              <span class="pm-radio"></span>
              <span class="pm-icon">
                <svg width="28" height="28" viewBox="0 0 40 40"><rect width="40" height="40" rx="8" fill="#07C160"/><text x="50%" y="57%" dominant-baseline="middle" text-anchor="middle" font-size="9" font-weight="800" fill="#fff">微信</text></svg>
              </span>
              <span class="pm-label">微信</span>
            </label>

            <!-- Card -->
            <label class="pm-option">
              <input type="radio" name="method" value="card" required/>
              <span class="pm-radio"></span>
              <span class="pm-icon pm-icon--cards">
                <svg width="28" height="18" viewBox="0 0 40 26"><rect width="40" height="26" rx="4" fill="#1A1F71"/><rect y="6" width="40" height="6" fill="#F7B731"/></svg>
                <svg width="28" height="18" viewBox="0 0 40 26"><rect width="40" height="26" rx="4" fill="#EB001B"/><circle cx="14" cy="13" r="10" fill="#EB001B"/><circle cx="26" cy="13" r="10" fill="#F79E1B"/><path d="M20 6.8a10 10 0 010 12.4A10 10 0 0120 6.8z" fill="#FF5F00"/></svg>
              </span>
              <span class="pm-label">
                银行卡支付
                <span class="pm-surcharge">（额外3%手续费）</span>
              </span>
            </label>

            <!-- IBP: Instant ACH -->
            <label class="pm-option<% if (!pkg.ibpAvailable) { %> pm-option--disabled<% } %>">
              <input type="radio" name="method" value="ibp" required <% if (!pkg.ibpAvailable) { %>disabled<% } %>/>
              <span class="pm-radio"></span>
              <span class="pm-icon">
                <svg width="28" height="28" viewBox="0 0 40 40" fill="none">
                  <rect width="40" height="40" rx="8" fill="#EEF0FF"/>
                  <rect x="6" y="20" width="4" height="12" rx="1" fill="#6B5ECD"/>
                  <rect x="12" y="16" width="4" height="16" rx="1" fill="#6B5ECD"/>
                  <rect x="18" y="12" width="4" height="20" rx="1" fill="#6B5ECD"/>
                  <rect x="24" y="16" width="4" height="16" rx="1" fill="#6B5ECD"/>
                  <rect x="30" y="20" width="4" height="12" rx="1" fill="#6B5ECD"/>
                  <rect x="4" y="18" width="32" height="2" rx="1" fill="#C5BFEF"/>
                </svg>
              </span>
              <span class="pm-label">
                ACH直接借记
                <span class="pm-note">（立刻到账）</span>
                <% if (!pkg.ibpAvailable) { %>
                <span class="pm-unavailable">Not available for this package</span>
                <% } %>
              </span>
            </label>

            <!-- ACH -->
            <label class="pm-option<% if (!pkg.achAvailable) { %> pm-option--disabled<% } %>">
              <input type="radio" name="method" value="ach" required <% if (!pkg.achAvailable) { %>disabled<% } %>/>
              <span class="pm-radio"></span>
              <span class="pm-icon">
                <span class="pm-ach-badge">ACH</span>
              </span>
              <span class="pm-label">
                ACH直接借记
                <span class="pm-note">（延时到账，预计1–4个工作日）</span>
                <% if (!pkg.achAvailable) { %>
                <span class="pm-unavailable">Not available for this package</span>
                <% } %>
              </span>
            </label>

          </div>

          <button type="submit" class="btn-next" id="next-btn" disabled>下一步</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    const radios = document.querySelectorAll('.pm-list input[type="radio"]');
    const nextBtn = document.getElementById('next-btn');
    radios.forEach(r => r.addEventListener('change', () => {
      nextBtn.disabled = false;
    }));
  </script>
</body>
</html>
