<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>LingoAce – Checkout</title>
  <link rel="stylesheet" href="/css/base.css"/>
  <link rel="stylesheet" href="/css/layout.css"/>
  <link rel="stylesheet" href="/css/checkout.css"/>
  <script src="https://js.stripe.com/dahlia/stripe.js"></script>
</head>
<body>
  <%- include('partials/topbar') %>
  <%- include('partials/navbar') %>

  <div class="checkout-shell">
    <div class="checkout-back">
      <a href="/book-class" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Back to Book Class
      </a>
    </div>

    <div class="checkout-layout">
      <!-- Order summary -->
      <div class="order-summary">
        <div class="order-logo">
          <div class="order-logo-icon">
            <svg width="28" height="28" viewBox="0 0 40 40">
              <circle cx="20" cy="20" r="20" fill="#6B5ECD"/>
              <ellipse cx="20" cy="22" rx="10" ry="8" fill="#F5A623"/>
              <circle cx="16" cy="18" r="3" fill="#fff"/>
              <circle cx="24" cy="18" r="3" fill="#fff"/>
              <circle cx="16" cy="18" r="1.5" fill="#333"/>
              <circle cx="24" cy="18" r="1.5" fill="#333"/>
            </svg>
          </div>
          <span class="order-brand">LingoAce</span>
        </div>

        <h2 class="order-title">Class Package</h2>

        <div class="order-item">
          <div class="order-item-info">
            <p class="order-item-name">LingoAce <%= pkg.name %></p>
            <p class="order-item-desc"><%= pkg.lessons %> Mandarin lessons · Certified teachers</p>
            <p class="order-item-per"><%= pkg.perLesson %></p>
          </div>
          <p class="order-item-price"><%= pkg.displayPrice %></p>
        </div>

        <div class="order-divider"></div>

        <div class="order-total-row">
          <span>Subtotal</span>
          <span><%= pkg.displayPrice %></span>
        </div>
        <div class="order-total-row order-total-row--total">
          <span>Total</span>
          <span><%= pkg.displayPrice %></span>
        </div>

        <div class="order-features">
          <div class="order-feature">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#34C759" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Flexible scheduling — book when you want
          </div>
          <div class="order-feature">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#34C759" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Native-speaking certified teachers
          </div>
          <div class="order-feature">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#34C759" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            Valid for 6 months from purchase
          </div>
        </div>
      </div>

      <!-- Payment section -->
      <div class="payment-section">
        <!-- Stripe Payment Element -->
        <div class="payment-block">
          <h3 class="payment-block-title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            Complete your payment
          </h3>
          <% if (isCard) { %>
          <div class="surcharge-banner">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            A 3% card processing fee has been applied to this order.
          </div>
          <% } %>
          <div id="checkout-container">
            <div id="checkout-loading" class="checkout-loading">
              <div class="spinner"></div>
              <p>Loading secure payment form…</p>
            </div>
            <form id="payment-form" style="display:none;">
              <div id="payment-element" style="margin-bottom:20px;"></div>
              <div id="payment-errors" class="payment-errors" style="display:none;"></div>
              <button id="submit-btn" class="btn-primary btn-submit" type="submit">
                <span id="submit-label">Pay <%= pkg.displayPrice %></span>
                <div id="submit-spinner" class="spinner spinner--sm" style="display:none;"></div>
              </button>
            </form>
          </div>
        </div>

        <!-- Change payment method -->
        <a href="/book-class/payment?package=<%= pkg.lessons %>" class="btn-change-method">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          Change payment method
        </a>

        <p class="checkout-secure">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          Secured by Stripe · SSL encrypted
        </p>
      </div>
    </div>
  </div>

  <script>
    const publishableKey = '<%= publishableKey %>';
    const selectedPackage = '<%= pkg.lessons %>';
    const selectedMethod = '<%= method %>';
    const currency = '<%= pkg.currency %>';
    const unitAmount = <%= unitAmount %>;
    const paymentMethodTypes = <%- JSON.stringify(paymentMethodTypes) %>;
  </script>
  <script src="/js/checkout.js"></script>
</body>
</html>
